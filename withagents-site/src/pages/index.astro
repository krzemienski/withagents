---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import SectionNumber from '@/components/SectionNumber.astro';
import ProductCard from '@/components/ProductCard.astro';
import WritingRow from '@/components/WritingRow.astro';
import ActiveDeploymentRow from '@/components/ActiveDeploymentRow.astro';

const products = [
  {
    name: 'Runbooks',
    slug: 'runbooks',
    tagline: 'View Documentation',
    description: 'Deterministic execution paths for non-deterministic models. A framework for constraining agent behavior safely.',
    sysNum: 'SYS_01',
    icon: 'book_4',
  },
  {
    name: 'Memory Layer',
    slug: 'memory-layer',
    tagline: 'View Architecture',
    description: 'State management built for persistence. Semantic caching and structured retrieval patterns.',
    sysNum: 'SYS_02',
    icon: 'database',
  },
  {
    name: 'Operator UI',
    slug: 'operator-ui',
    tagline: 'Explore Components',
    description: 'Human-in-the-loop interfaces. High-fidelity dashboards for monitoring fleet health and intervening in agent flows.',
    sysNum: 'SYS_03',
    icon: 'terminal',
  },
];

const posts = [
  {
    href: '/writing/agent-workflows-operating-systems',
    title: 'Agent workflows should read like operating systems.',
    excerpt: 'Moving away from script-kiddie prompting towards robust, interruptible state machines.',
    date: 'Apr 12, 2026',
    kind: 'Essay',
    readTime: '8 min',
  },
  {
    href: '/writing/context-persistence-product-design',
    title: 'The fallacy of universal context windows.',
    excerpt: 'Why throwing 100k tokens at a problem is an architectural failure, not a solution.',
    date: 'Mar 28, 2026',
    kind: 'Field Note',
    readTime: '5 min',
  },
];

const repos = [
  { name: 'agent-contracts', version: 'v1.2.4', status: 'active' as const },
  { name: 'trace-timeline', version: 'v0.9.1-beta', status: 'active' as const },
  { name: 'eval-suite', version: 'Building...', status: 'building' as const },
];
---

<BaseLayout
  title="WithAgents — Applied Agent Design"
  description="A home for products, systems-first writing, and field-tested open source work."
>
  <Nav />

  <main class="relative z-10 flex flex-col items-center w-full">

    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="relative w-full max-w-[1440px] overflow-hidden px-6 py-32 md:py-48">
      <!-- Ambient glow -->
      <div
        class="pointer-events-none absolute top-0 right-0 h-[800px] w-[800px] -translate-y-1/2 translate-x-1/3 blur-[120px]"
        style="background:rgba(139,92,246,0.05);"
        aria-hidden="true"
      ></div>

      <div class="relative z-10 max-w-4xl">
        <!-- Status indicator -->
        <div class="mb-8 flex items-center gap-3">
          <span
            class="h-2 w-2 rounded-full"
            style="background:var(--color-accent-lime);"
            aria-hidden="true"
          ></span>
          <span class="font-mono text-xs uppercase tracking-widest text-muted">
            System Status: Nominal
          </span>
        </div>

        <h1
          class="font-display font-bold text-text mb-8 text-balance"
          style="font-size:clamp(48px,8vw,96px);letter-spacing:-0.03em;line-height:0.92;"
        >
          Applied Agent<br />Design.
        </h1>

        <p class="font-body text-xl text-muted mb-12 max-w-2xl leading-relaxed text-balance md:text-2xl">
          A home for products, systems-first writing, and field-tested open source work.
        </p>

        <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
          <a
            href="/products"
            class="group inline-flex items-center gap-3 font-body font-medium text-text transition-all duration-200 focus-visible:outline-accent"
            style="background:var(--color-accent);padding:16px 32px;border-radius:2px;"
            onmouseenter="this.style.boxShadow='0 0 20px rgba(139,92,246,0.4)'"
            onmouseleave="this.style.boxShadow='none'"
          >
            <span>Explore Products</span>
            <span class="material-symbols-outlined transition-transform duration-200 group-hover:translate-x-1" style="font-size:18px;">arrow_forward</span>
          </a>

          <a
            href="/writing"
            class="inline-flex items-center gap-3 font-mono text-sm text-muted transition-all duration-200 focus-visible:outline-accent"
            style="padding:16px 32px;border-radius:2px;border:1px solid rgba(255,255,255,0.10);"
            onmouseenter="this.style.borderColor='rgba(255,255,255,0.25)';this.style.background='var(--color-panel-2)'"
            onmouseleave="this.style.borderColor='rgba(255,255,255,0.10)';this.style.background='transparent'"
          >
            Read the Index
          </a>
        </div>
      </div>
    </section>

    <!-- ── Product Pillars ───────────────────────────────────── -->
    <section class="w-full max-w-[1440px] px-6 py-24" id="products" style="border-top:1px solid var(--color-hair);">
      <div class="mb-16 flex items-end justify-between">
        <div>
          <SectionNumber num="01" label="Architecture" />
          <h2 class="mt-4 font-display text-3xl font-bold text-text tracking-tight md:text-4xl">
            Core Infrastructure
          </h2>
        </div>
        <a href="/products" class="hidden font-mono text-xs text-muted transition-colors hover:text-accent md:block">
          View all →
        </a>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {products.map(p => <ProductCard {...p} />)}
      </div>
    </section>

    <!-- ── Latest Writing ────────────────────────────────────── -->
    <section class="w-full max-w-[1440px] px-6 py-24" id="writing">
      <div class="flex flex-col gap-16 md:flex-row">
        <!-- Left column -->
        <div class="md:w-1/3">
          <SectionNumber num="02" label="The Index" />
          <h2 class="mt-4 font-display text-3xl font-bold text-text tracking-tight mb-6">
            Systems-First Writing
          </h2>
          <p class="font-body text-sm text-muted leading-relaxed mb-8">
            Essays and technical notes on building reliable, agentic systems in production environments.
          </p>
          <a
            href="/writing"
            class="inline-flex items-center gap-2 font-mono text-xs text-muted transition-colors hover:text-accent focus-visible:outline-accent"
          >
            <span>View Full Index</span>
            <span class="material-symbols-outlined" style="font-size:14px;">arrow_forward</span>
          </a>
        </div>

        <!-- Right column: article rows -->
        <div class="flex flex-col md:w-2/3">
          {posts.map(p => (
            <WritingRow
              href={p.href}
              title={p.title}
              excerpt={p.excerpt}
              date={p.date}
              kind={p.kind}
              readTime={p.readTime}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- ── Active Deployments ────────────────────────────────── -->
    <section class="w-full max-w-[1440px] px-6 py-12">
      <ActiveDeploymentRow repos={repos} />
    </section>

    <!-- ── Advisory / Applied Systems ───────────────────────── -->
    <section class="mt-24 w-full py-32" style="background:var(--color-panel-1);">
      <div class="mx-auto flex max-w-[1440px] flex-col items-start justify-between gap-12 px-6 md:flex-row md:items-end">
        <div class="max-w-2xl">
          <SectionNumber num="03" label="Advisory" />
          <h2 class="mt-6 font-display text-4xl font-bold text-text tracking-tight text-balance md:text-5xl">
            Applied Systems.
          </h2>
          <p class="mt-6 font-body text-lg text-muted leading-relaxed text-balance">
            Quiet, implementation-first collaboration for organizations introducing agentic workflows into production.
          </p>
        </div>

        <a
          href="/about"
          class="inline-flex items-center gap-3 shrink-0 font-body font-medium text-void transition-colors duration-200 focus-visible:outline-accent"
          style="background:var(--color-text);padding:16px 32px;border-radius:2px;"
          onmouseenter="this.style.background='#ffffff'"
          onmouseleave="this.style.background='var(--color-text)'"
        >
          <span>Start a conversation</span>
          <span class="material-symbols-outlined" style="font-size:16px;">mail</span>
        </a>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
