---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';

const areas = [
  {
    tag: 'Workflow',
    tagColor: 'var(--color-accent-lime)',
    title: 'Internal copilots for domain-specific workflows',
  },
  {
    tag: 'Interface',
    tagColor: 'var(--color-accent)',
    title: 'Operator UX for human-in-the-loop review',
  },
  {
    tag: 'Infrastructure',
    tagColor: 'var(--color-muted)',
    title: 'Agent orchestration for high-signal internal tasks',
  },
  {
    tag: 'Knowledge',
    tagColor: '#EC4899',
    title: 'Knowledge interfaces and tool-safe automation',
  },
];
---

<BaseLayout
  title="About — WithAgents"
  description="A home for applied agent design. Products, open-source work, and writing about what holds up in production."
  brand="frame"
>
  <Nav current="about" />

  <main class="relative z-10 w-full flex-grow">
    <div class="mx-auto max-w-[1440px] px-6 md:px-12 lg:px-24 py-24 space-y-32">

      <!-- Header -->
      <header class="max-w-4xl">
        <h1
          class="font-display text-5xl font-bold tracking-tighter text-text leading-tight mb-6 md:text-7xl"
          style="letter-spacing:-0.02em;"
        >
          About WithAgents.
        </h1>
        <p class="font-body text-xl text-muted font-light leading-relaxed max-w-2xl md:text-2xl">
          A home for applied agent design.
        </p>
      </header>

      <!-- The Thesis -->
      <section class="max-w-4xl grid grid-cols-1 gap-12 md:grid-cols-12">
        <div class="md:col-span-4">
          <h2 class="font-mono text-sm uppercase tracking-widest text-muted mb-4">The Thesis</h2>
          <div class="h-px w-12" style="background:rgba(255,255,255,0.10);"></div>
        </div>
        <div class="md:col-span-8 space-y-8 font-body text-lg text-muted leading-relaxed font-light">
          <p>
            We build environments that prioritize systems over spectacle. The "Technical Curator" philosophy demands that every interaction is a deliberate act of design, rejecting the vague "chat" paradigms in favor of structured, purposeful workflows.
          </p>
          <p>
            Our approach to applied agent design centers on creating high-fidelity instruments. We believe intelligence is most valuable when integrated seamlessly into complex, domain-specific tasks — demanding interfaces that respect the user's expertise and time.
          </p>
        </div>
      </section>

      <!-- In practice -->
      <section class="space-y-12">
        <div class="flex items-center gap-6">
          <h2 class="font-display text-3xl font-semibold tracking-tight text-text">In practice</h2>
          <div class="flex-grow h-px" style="background:var(--color-panel-2);"></div>
        </div>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {areas.slice(0, 3).map(area => (
            <div
              class="group flex flex-col justify-between p-8 transition-colors duration-300"
              style="background:var(--color-panel-1);border:1px solid var(--color-hair);"
              onmouseenter="this.style.background='var(--color-panel-2)'"
              onmouseleave="this.style.background='var(--color-panel-1)'"
            >
              <div class="space-y-4">
                <span
                  class="font-mono text-xs uppercase tracking-wider inline-block"
                  style={`background:var(--color-panel-3);padding:3px 8px;color:${area.tagColor};`}
                >{area.tag}</span>
                <h3 class="font-display text-xl font-medium text-text leading-snug">{area.title}</h3>
              </div>
              <div class="mt-12 flex justify-end">
                <span class="material-symbols-outlined text-muted transition-colors group-hover:text-accent" style="font-size:20px;">arrow_forward</span>
              </div>
            </div>
          ))}
          <!-- 4th area: spans 2 cols on md -->
          <div
            class="group flex flex-col justify-between p-8 transition-colors duration-300 md:col-span-2 lg:col-span-1"
            style="background:var(--color-panel-1);border:1px solid var(--color-hair);"
            onmouseenter="this.style.background='var(--color-panel-2)'"
            onmouseleave="this.style.background='var(--color-panel-1)'"
          >
            <div class="space-y-4">
              <span
                class="font-mono text-xs uppercase tracking-wider inline-block"
                style={`background:var(--color-panel-3);padding:3px 8px;color:${areas[3].tagColor};`}
              >{areas[3].tag}</span>
              <h3 class="font-display text-xl font-medium text-text leading-snug">{areas[3].title}</h3>
            </div>
            <div class="mt-12 flex justify-end">
              <span class="material-symbols-outlined text-muted transition-colors group-hover:text-accent" style="font-size:20px;">arrow_forward</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Quiet collaboration block -->
      <section
        class="relative overflow-hidden flex flex-col items-center text-center space-y-8 px-8 py-16 md:px-16 md:py-24"
        style="background:var(--color-panel-1);border:1px solid var(--color-hair);"
      >
        <!-- Subtle radial glow -->
        <div
          class="pointer-events-none absolute inset-0"
          style="background:radial-gradient(ellipse at top,rgba(139,92,246,0.05) 0%,transparent 60%);"
          aria-hidden="true"
        ></div>

        <div class="relative z-10 max-w-2xl space-y-6">
          <h2 class="font-display text-3xl font-bold tracking-tight text-text md:text-4xl">
            Start a conversation.
          </h2>
          <p class="font-body text-lg text-muted font-light">
            We collaborate with organizations to design and deploy specialized agent systems. Quiet, implementation-first engagement.
          </p>

          <!-- Email form -->
          <form
            class="flex flex-col gap-4 sm:flex-row sm:justify-center pt-4"
            onsubmit="event.preventDefault()"
          >
            <input
              type="email"
              placeholder="your@email.com"
              class="bg-transparent border-0 text-text placeholder-muted-2 font-mono text-sm focus:ring-0 transition-colors w-full sm:w-64"
              style="border-bottom:1px solid rgba(255,255,255,0.20);padding:12px 0;"
            />
            <button
              type="submit"
              class="font-mono text-[11px] uppercase tracking-widest text-text transition-all duration-200"
              style="border:1px solid rgba(255,255,255,0.15);padding:12px 24px;border-radius:2px;"
              onmouseenter="this.style.borderColor='rgba(139,92,246,0.5)';this.style.background='var(--color-panel-2)'"
              onmouseleave="this.style.borderColor='rgba(255,255,255,0.15)';this.style.background='transparent'"
            >Send</button>
          </form>
        </div>
      </section>

      <!-- Network footer row -->
      <section
        class="flex flex-col justify-between items-start gap-8 pt-12 pb-24 md:flex-row md:items-center"
        style="border-top:1px solid var(--color-hair);"
      >
        <div class="font-mono text-xs text-muted-2 space-y-2 uppercase tracking-widest">
          <p>Designed &amp; Engineered by</p>
          <p class="text-muted">The WithAgents Research Network</p>
        </div>
        <div class="flex gap-6">
          {['Twitter', 'GitHub', 'RSS'].map(link => (
            <a
              href="#"
              class="font-mono text-xs uppercase tracking-widest text-muted-2 hover:text-accent transition-colors focus-visible:outline-accent"
            >{link}</a>
          ))}
        </div>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>
