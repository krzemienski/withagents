---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import ConsultForm from '@/components/ConsultForm.astro';

// ── UTM capture from inbound URL ──────────────────────────────────────────────
// Query params are read server-side so they populate the hidden form fields
// on initial render, surviving even if the user navigates off and back.
const { searchParams } = Astro.url;
const utmSource   = searchParams.get('utm_source')   ?? '';
const utmMedium   = searchParams.get('utm_medium')   ?? '';
const utmCampaign = searchParams.get('utm_campaign') ?? '';
const serverError = searchParams.get('error')        ?? '';

// ── What I do ─────────────────────────────────────────────────────────────────
const areas = [
  {
    tag:      'Agent architecture',
    tagColor: 'var(--color-accent)',
    title:    'Design multi-agent systems that hold up in production',
    body:     'Orchestration patterns, tool contracts, human-in-the-loop gates, failure recovery. Not demos — deployed systems.',
  },
  {
    tag:      'Operator UX',
    tagColor: 'var(--color-accent-alt)',
    title:    'Build the interface layer between agents and people',
    body:     'Review queues, approval flows, transparency dashboards. The part most teams skip and regret.',
  },
  {
    tag:      'Validation infra',
    tagColor: 'var(--color-accent-lime)',
    title:    'Replace fragile mocks with real functional validation',
    body:     'Evidence-based gates. No test doubles. Build it, run it, capture proof — then ship.',
  },
  {
    tag:      'Knowledge systems',
    tagColor: 'var(--color-muted)',
    title:    'Persistent context and tool-safe automation',
    body:     'Memory layers, structured retrieval, safe tool exposure. Agents that remember what matters.',
  },
];

// ── Engagement styles ─────────────────────────────────────────────────────────
const engagements = [
  {
    label:  'Architecture review',
    length: '1–2 days',
    desc:   'Focused audit of your agent system design. Written findings + one working session.',
  },
  {
    label:  'Embedded sprint',
    length: '1–2 weeks',
    desc:   'Pair directly on a specific problem. I write code, not slides.',
  },
  {
    label:  'Ongoing collaboration',
    length: 'Monthly retainer',
    desc:   'Reserved capacity for teams that ship continuously and need a technical partner who already knows the system.',
  },
];
---

<BaseLayout
  title="Work — WithAgents"
  description="Applied agent design: architecture reviews, embedded sprints, and ongoing collaboration for teams building real agent systems."
  kind="about"
>
  <Nav current="work" />

  <main class="relative z-10 w-full flex-grow">
    <div class="mx-auto max-w-[1440px] px-6 md:px-12 lg:px-24 py-24 space-y-32">

      <!-- ── Hero ──────────────────────────────────────────────────────────── -->
      <header class="max-w-4xl">
        <p class="font-mono text-xs uppercase tracking-widest text-muted mb-6">
          Selected areas · Applied work
        </p>
        <h1
          class="font-display text-5xl font-bold tracking-tight text-text leading-tight mb-8 md:text-7xl"
          style="letter-spacing:-0.02em;"
        >
          Quiet collaboration<br />on hard agent problems.
        </h1>
        <p class="font-body text-xl text-muted font-light leading-relaxed max-w-2xl md:text-2xl">
          I work with a small number of teams at a time. No pitch decks.
          Describe what you're building and I'll tell you honestly if I can help.
        </p>
        <div class="mt-10">
          <a
            href="#consult"
            class="inline-flex items-center gap-2 font-mono text-sm uppercase tracking-widest text-text transition-all duration-200 focus-visible:outline-accent"
            style="border:1px solid rgba(255,255,255,0.15);padding:14px 28px;border-radius:var(--radius-xs);"
            onmouseenter="this.style.borderColor='rgba(139,92,246,0.5)';this.style.background='var(--color-panel-2)'"
            onmouseleave="this.style.borderColor='rgba(255,255,255,0.15)';this.style.background='transparent'"
          >
            Start a conversation
            <span class="material-symbols-outlined" style="font-size:16px;" aria-hidden="true">south</span>
          </a>
        </div>
      </header>

      <!-- ── What I do ─────────────────────────────────────────────────────── -->
      <section aria-labelledby="what-i-do-heading">
        <div class="flex items-center gap-6 mb-12">
          <h2
            id="what-i-do-heading"
            class="font-display text-3xl font-semibold tracking-tight text-text"
          >In practice</h2>
          <div class="flex-grow h-px" style="background:var(--color-panel-2);"></div>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
          {areas.map(area => (
            <div
              class="group flex flex-col justify-between p-8 transition-colors duration-300"
              style="background:var(--color-panel-1);border:1px solid var(--color-hair);"
              onmouseenter="this.style.background='var(--color-panel-2)'"
              onmouseleave="this.style.background='var(--color-panel-1)'"
            >
              <div class="space-y-4">
                <span
                  class="font-mono text-xs uppercase tracking-wider inline-block"
                  style={`background:var(--color-panel-3);padding:3px 8px;color:${area.tagColor};border-radius:var(--radius-xs);`}
                >{area.tag}</span>
                <h3 class="font-display text-xl font-medium text-text leading-snug">{area.title}</h3>
                <p class="font-body text-sm text-muted leading-relaxed font-light">{area.body}</p>
              </div>
              <div class="mt-10 flex justify-end">
                <span
                  class="material-symbols-outlined text-muted transition-colors group-hover:text-accent"
                  style="font-size:20px;"
                  aria-hidden="true"
                >arrow_forward</span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- ── How it works ───────────────────────────────────────────────────── -->
      <section aria-labelledby="how-heading" class="max-w-4xl">
        <div class="grid grid-cols-1 gap-12 md:grid-cols-12">
          <div class="md:col-span-4">
            <h2
              id="how-heading"
              class="font-mono text-sm uppercase tracking-widest text-muted mb-4"
            >How it works</h2>
            <div class="h-px w-12" style="background:var(--color-hair);"></div>
          </div>
          <div class="md:col-span-8 space-y-10">
            {engagements.map((e, i) => (
              <div class="flex gap-6">
                <div
                  class="flex-shrink-0 w-8 h-8 flex items-center justify-center font-mono text-xs text-muted"
                  style="border:1px solid var(--color-hair);border-radius:var(--radius-xs);"
                  aria-hidden="true"
                >
                  {String(i + 1).padStart(2, '0')}
                </div>
                <div class="space-y-2">
                  <div class="flex items-baseline gap-3 flex-wrap">
                    <h3 class="font-display text-lg font-medium text-text">{e.label}</h3>
                    <span
                      class="font-mono text-[10px] uppercase tracking-widest"
                      style="color:var(--color-muted-2);background:var(--color-panel-2);padding:2px 7px;border-radius:var(--radius-xs);"
                    >{e.length}</span>
                  </div>
                  <p class="font-body text-sm text-muted leading-relaxed font-light">{e.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ── Constraints section ────────────────────────────────────────────── -->
      <section
        class="max-w-4xl grid grid-cols-1 gap-12 md:grid-cols-12"
        aria-labelledby="constraints-heading"
      >
        <div class="md:col-span-4">
          <h2
            id="constraints-heading"
            class="font-mono text-sm uppercase tracking-widest text-muted mb-4"
          >What I don't do</h2>
          <div class="h-px w-12" style="background:var(--color-hair);"></div>
        </div>
        <div class="md:col-span-8 space-y-4 font-body text-base text-muted leading-relaxed font-light">
          <p>Not available: staff augmentation, long-term agency retainers, work where "AI" is marketing copy rather than load-bearing infrastructure.</p>
          <p>Not seeking: a job. Full-time at WithAgents.</p>
          <p>I take on 2–3 projects at a time. Availability is genuinely limited.</p>
        </div>
      </section>

      <!-- ── Consult form ───────────────────────────────────────────────────── -->
      <section
        id="consult"
        class="relative overflow-hidden px-8 py-16 md:px-16 md:py-24 scroll-mt-24"
        style="background:var(--color-panel-1);border:1px solid var(--color-hair);"
        aria-labelledby="consult-heading"
      >
        <!-- Radial glow matching CTABlock pattern -->
        <div
          class="pointer-events-none absolute top-0 right-0 h-64 w-64 blur-[100px]"
          style="background:var(--color-wash);"
          aria-hidden="true"
        ></div>

        <div class="relative z-10 max-w-2xl mx-auto space-y-10">
          <div class="space-y-4">
            <h2
              id="consult-heading"
              class="font-display text-3xl font-bold tracking-tight text-text md:text-4xl"
            >
              Start a conversation.
            </h2>
            <p class="font-body text-lg text-muted font-light leading-relaxed">
              Describe what you're building. I'll respond within a few days —
              and if it's a fit, we'll find a time to talk.
            </p>
          </div>

          <ConsultForm
            utmSource={utmSource}
            utmMedium={utmMedium}
            utmCampaign={utmCampaign}
            serverError={serverError}
          />
        </div>
      </section>

      <!-- ── Calendly embed fallback ────────────────────────────────────────── -->
      <!--
        Shown only if JS is disabled or the user wants to book directly without
        filling the form. The form is the primary path; Calendly is the fallback.
        Replace the data-url value with your actual Calendly link at Phase 11.
      -->
      <section
        class="max-w-2xl mx-auto text-center space-y-6"
        aria-label="Direct booking alternative"
      >
        <p class="font-mono text-xs uppercase tracking-widest text-muted">
          Prefer to pick a time directly?
        </p>
        <a
          href={import.meta.env.CALENDLY_URL ?? 'https://calendly.com/nickk'}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-mono text-sm uppercase tracking-widest text-muted transition-all duration-200 hover:text-text focus-visible:outline-accent"
          style="border-bottom:1px solid var(--color-hair);padding-bottom:4px;"
        >
          Book a 30-min call on Calendly
          <span class="material-symbols-outlined" style="font-size:14px;" aria-hidden="true">open_in_new</span>
        </a>
        <p class="font-mono text-[10px] text-muted-2 uppercase tracking-widest">
          TODO(phase-11-credentials): replace href with env.CALENDLY_URL
        </p>
      </section>

    </div>
  </main>

  <Footer />
</BaseLayout>
