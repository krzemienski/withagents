---
---

<footer
  class="w-full"
  style="border-top:1px solid var(--color-hair);"
>
  <div class="mx-auto max-w-[1440px] px-6 py-12">
    <!-- 5-col grid -->
    <div class="grid grid-cols-2 gap-8 md:grid-cols-5 md:gap-12 mb-12">
      <!-- Wordmark + positioning -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="wordmark text-lg text-text mb-3 block focus-visible:outline-accent">withagents</a>
        <p class="font-mono text-xs text-muted-2 leading-relaxed">
          A home for applied agent design: products, open-source work, and writing about what holds up in production.
        </p>
      </div>

      <!-- Products -->
      <div>
        <p class="font-mono text-[10px] uppercase tracking-widest text-muted-2 mb-4">Products</p>
        <ul class="space-y-3">
          <li><a href="/products/runbooks" class="font-mono text-xs text-muted hover:text-text transition-colors">Runbooks</a></li>
          <li><a href="/products/memory-layer" class="font-mono text-xs text-muted hover:text-text transition-colors">Memory Layer</a></li>
          <li><a href="/products/operator-ui" class="font-mono text-xs text-muted hover:text-text transition-colors">Operator UI</a></li>
        </ul>
      </div>

      <!-- Writing -->
      <div>
        <p class="font-mono text-[10px] uppercase tracking-widest text-muted-2 mb-4">Writing</p>
        <ul class="space-y-3">
          <li><a href="/writing" class="font-mono text-xs text-muted hover:text-text transition-colors">The Index</a></li>
          <li><a href="/writing" class="font-mono text-xs text-muted hover:text-text transition-colors">Essays</a></li>
          <li><a href="/writing" class="font-mono text-xs text-muted hover:text-text transition-colors">Field Notes</a></li>
        </ul>
      </div>

      <!-- Open Source -->
      <div>
        <p class="font-mono text-[10px] uppercase tracking-widest text-muted-2 mb-4">Open Source</p>
        <ul class="space-y-3">
          <li><a href="/opensource" class="font-mono text-xs text-muted hover:text-text transition-colors">agent-contracts</a></li>
          <li><a href="/opensource" class="font-mono text-xs text-muted hover:text-text transition-colors">trace-timeline</a></li>
          <li><a href="/opensource" class="font-mono text-xs text-muted hover:text-text transition-colors">context-layers</a></li>
        </ul>
      </div>

      <!-- About -->
      <div>
        <p class="font-mono text-[10px] uppercase tracking-widest text-muted-2 mb-4">Company</p>
        <ul class="space-y-3">
          <li><a href="/about" class="font-mono text-xs text-muted hover:text-text transition-colors">About</a></li>
          <li><a href="/about" class="font-mono text-xs text-muted hover:text-text transition-colors">Applied Work</a></li>
          <li><a href="/hyper" class="font-mono text-xs text-muted hover:text-text transition-colors">Hyper</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom row -->
    <div
      class="flex flex-col items-start justify-between gap-4 pt-8 sm:flex-row sm:items-center"
      style="border-top:1px solid var(--color-hair);"
    >
      <p class="font-mono text-[10px] uppercase tracking-widest text-muted-2">
        &copy; 2026 WithAgents
      </p>

      <div class="flex items-center gap-6">
        <a href="#" aria-label="RSS feed" class="font-mono text-[10px] uppercase tracking-widest text-muted-2 hover:text-text transition-colors">RSS</a>
        <a href="https://github.com" aria-label="GitHub" class="font-mono text-[10px] uppercase tracking-widest text-muted-2 hover:text-text transition-colors">GitHub</a>
        <a href="/about" class="font-mono text-[10px] uppercase tracking-widest text-muted-2 hover:text-accent transition-colors">
          Start a conversation ↗
        </a>
      </div>
    </div>
  </div>
</footer>
