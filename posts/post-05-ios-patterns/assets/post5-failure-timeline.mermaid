graph TD
    subgraph attempt1["Attempt 1: Direct API — Day 0.5"]
        A1["Import anthropic SDK"] --> A2["AuthenticationError"]
        A2 --> A3["Claude Code uses OAuth<br/>not ANTHROPIC_API_KEY"]
    end

    subgraph attempt2["Attempt 2: ClaudeCodeSDK in Vapor — Day 1-2.5"]
