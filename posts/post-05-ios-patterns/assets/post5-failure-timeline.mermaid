        B2 --> B3["AsyncStream never yields"]
        B3 --> B4["RunLoop vs NIO<br/>impedance mismatch"]
        B4 --> B5["Three workarounds<br/>all deadlock"]
    end

    subgraph attempt3["Attempt 3: JavaScript SDK — Day 2.5-3"]
        C1["Add Node.js runtime"] --> C2["Same AuthenticationError"]
        C2 --> C3["OAuth wall identical<br/>to Attempt 1"]
    end

    subgraph attempt4["Attempt 4: CLI Subprocess — Day 3-4.5"]
        D1["Spawn claude CLI"] --> D2["Works in terminal"]
        D2 --> D3["Silent failure in<br/>Claude Code session"]
        D3 --> D4["CLAUDECODE=1<br/>nesting detection"]
        D4 --> D5["Three-line env<br/>var fix"]
        D5 --> D6["SUCCESS"]
    end

    attempt1 --> attempt2
    attempt2 --> attempt3
    attempt3 --> attempt4

